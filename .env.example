# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (PostGIS + pgvector)
POSTGRES_DB=eospatial
POSTGRES_USER=eospatial
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-совместимое объектное хранилище)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=eospatial
# Публичный адрес MinIO для ссылок пользователю (открывает браузер).
# Dev: http://localhost:9000 (порт опубликован в docker-compose).
# Prod: заменить на реальный домен MinIO (например https://files.eospatial.kz).
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
