# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
# "backend" — имя docker-сервиса; нужно, потому что next.config.ts
# проксирует /api/* на http://backend:8000, и Host-заголовок запроса
# приходит в Django как "backend:8000".
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Origin фронтенда, которому Django доверяет для проверки CSRF-Origin.
# Прод: заменить/дополнить реальным доменом (например https://progeo.kz).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL (PostGIS + pgvector)
POSTGRES_DB=progeo
POSTGRES_USER=progeo
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-совместимое объектное хранилище)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=progeo
# Публичный адрес MinIO для ссылок пользователю (открывает браузер).
# Dev: http://localhost:9000 (порт опубликован в docker-compose).
# Prod: заменить на реальный домен MinIO (например https://files.progeo.kz).
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Frontend: адрес backend внутри docker-сети для server-side проксирования /api/*
# (next.config.ts rewrites). Задаётся напрямую в docker-compose.yml (имя сервиса
# "backend"), здесь — только для справки/локального запуска фронтенда без Docker.
INTERNAL_API_URL=http://backend:8000
